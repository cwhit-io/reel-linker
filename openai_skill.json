{
  "openapi": "3.1.0",
  "info": {
    "title": "Reel Link Scraper",
    "description": "Fetches the latest reel/short links from Facebook, Instagram, and YouTube",
    "version": "v1.0.0"
  },
  "servers": [
    {
      "url": "http://50.106.85.233:5000"
    }
  ],
  "paths": {
    "/api/reels": {
      "get": {
        "summary": "Get reel links from all platforms",
        "description": "Fetches reel links from all platforms (Facebook, Instagram, YouTube)",
        "operationId": "getAllReels",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                      "type": "object",
                      "properties": {
                        "facebook": { "type": "string" },
                        "instagram": { "type": "string" },
                        "youtube": { "type": "string" }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/facebook": {
      "get": {
        "summary": "Get the latest Facebook reel",
        "description": "Fetches the latest reel from Facebook",
        "operationId": "getFacebookReel",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "platform": { "type": "string" },
                    "url": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/instagram": {
      "get": {
        "summary": "Get the latest Instagram reel",
        "description": "Fetches the latest reel from Instagram",
        "operationId": "getInstagramReel",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "platform": { "type": "string" },
                    "url": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/youtube": {
      "get": {
        "summary": "Get the latest YouTube short",
        "description": "Fetches the latest short from YouTube",
        "operationId": "getYouTubeShort",
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "platform": { "type": "string" },
                    "url": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
